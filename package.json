{
  "name": "my-agy-usage",
  "displayName": "My Antigravity Usage",
  "description": "A lightweight, status bar only quota monitor for Antigravity AI.",
  "version": "1.0.10",
  "publisher": "devcoramdeo",
  "icon": "logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/coramdeo643/my-agy-usage.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI"
  ],
  "keywords": [
    "antigravity",
    "quota",
    "usage",
    "ai",
    "gemini",
    "claude",
    "status bar",
    "monitor"
  ],
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "myAgyUsage.refresh",
        "title": "Refresh Quota Data",
        "category": "Antigravity Lite"
      },
      {
        "command": "myAgyUsage.openSettings",
        "title": "Open Extension Settings",
        "category": "Antigravity Lite"
      }
    ],
    "keybindings": [
      {
        "command": "myAgyUsage.refresh",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ],
    "configuration": {
      "title": "My Antigravity Usage",
      "properties": {
        "myAgyUsage.refreshInterval": {
          "type": "number",
          "default": 20,
          "minimum": 20,
          "maximum": 3600,
          "description": "Interval in seconds to refresh quota data (20-3600)."
        },
        "myAgyUsage.notifyOnReset": {
          "type": "boolean",
          "default": true,
          "description": "Show system notification when model quota resets or refreshes."
        },
        "myAgyUsage.statusBarModel": {
          "type": "string",
          "enum": [
            "all",
            "gemini",
            "claudeGpt"
          ],
          "enumDescriptions": [
            "Display all models (Gemini, Claude & GPT)",
            "Display Gemini models only",
            "Display Claude & GPT models only"
          ],
          "default": "all",
          "description": "Select which AI models to display on the status bar."
        },
        "myAgyUsage.statusBarMetric": {
          "type": "string",
          "enum": [
            "all",
            "percentOnly",
            "hourlyWeeklyOnly"
          ],
          "enumDescriptions": [
            "Display both percent and reset countdown for all windows",
            "Display remaining percentages only (hide countdowns)",
            "Display only the prevailing window metric (hourly 5-hour limit or weekly limit when depleting)"
          ],
          "default": "all",
          "description": "Select which quota metrics to display on the status bar."
        }
      }
    },
    "icons": {
      "myagy-gemini": {
        "description": "Official Monochrome Gemini Logo",
        "default": {
          "fontPath": "./resources/myicons-v8.woff",
          "fontCharacter": ""
